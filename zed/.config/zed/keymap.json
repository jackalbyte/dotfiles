[
  {
    "context": "Workspace",
    "bindings": {
      "f12": "workspace::ToggleBottomDock",
      "shift esc": "pane::CloseActiveItem",
    },
  },
  // ------------------------------------------------------------------
  // EDITOR (Normal Mode)
  // ------------------------------------------------------------------
  {
    "context": "Editor && vim_mode == normal && !VimWaiting && !menu",
    "bindings": {
      // --- Window / Split Management (Idiomatic 'space w') ---
      "space w v": "pane::SplitRight",
      "space w s": "pane::SplitDown",
      "space w q": "pane::CloseActiveItem",
      "space w o": "workspace::CloseAllDocks",
      //"space w h": "workspace::ActivatePaneLeft", // Redundant but muscle memory friendly
      //"space w l": "workspace::ActivatePaneRight",
      // "space w k": "workspace::ActivatePaneUp",
      // "space w j": "workspace::ActivatePaneDown",

      // --- Tabs ---
      "space x": "pane::CloseActiveItem",
      "space X": "pane::CloseOtherItems",

      // --- Panel Toggles ---
      "\\": "pane::RevealInProjectPanel",
      "space e": "project_panel::ToggleFocus", // NvimTree toggle feel
      "space t": "terminal_panel::ToggleFocus",

      // --- LSP & Code Actions ---
      "space a": "editor::ToggleCodeActions",
      "space r r": "editor::Rename",
      "space d": "editor::Hover",
      "space D": "diagnostics::Deploy",
      "g d": "editor::GoToDefinition",
      "g D": "editor::GoToDefinitionSplit",
      "g i": "editor::GoToImplementation",
      "g I": "editor::GoToImplementationSplit",
      "g t": "editor::GoToTypeDefinition",
      "g T": "editor::GoToTypeDefinitionSplit",
      "g r": "editor::FindAllReferences",
      "] d": "editor::GoToDiagnostic",
      "[ d": "editor::GoToPreviousDiagnostic",

      // --- Git ---
      "space h p": "editor::ToggleSelectedDiffHunks",
      "space h r": "git::Restore",
      "space v a": "git::Blame",
      "space v s": "git_panel::ToggleFocus",
      "] h": "editor::GoToHunk",
      "[ h": "editor::GoToPreviousHunk",

      // --- Find / Search ---
      "space f f": "file_finder::Toggle",
      "space f p": "projects::OpenRecent",
      "space f s": "pane::DeploySearch",
      "space s": "outline::Toggle",
      "space f m": "project_symbols::Toggle", // find method in IDEA

      // --- Markdown ---
      "space m p": "markdown::OpenPreview",
      "space m P": "markdown::OpenPreviewToTheSide",
      "f12": "workspace::ToggleBottomDock",
    },
  },
  // ------------------------------------------------------------------
  // EMPTY PANE (No file open)
  // ------------------------------------------------------------------
  {
    "context": "EmptyPane || SharedScreen",
    "bindings": {
      "space f f": "file_finder::Toggle",
      "space f p": "projects::OpenRecent",
      "space e": "project_panel::ToggleFocus",
    },
  },
  // ------------------------------------------------------------------
  // VISUAL MODE
  // ------------------------------------------------------------------
  {
    "context": "Editor && vim_mode == visual && !VimWaiting && !menu",
    "bindings": {
      "g c": "editor::ToggleComments",
      "space a": "editor::ToggleCodeActions", // Allow code actions on selection
    },
  },
  // ------------------------------------------------------------------
  // INSERT MODE (Better Escape)
  // ------------------------------------------------------------------
  {
    "context": "Editor && vim_mode == insert && !menu",
    "bindings": {
      "j j": "vim::NormalBefore",
      "j k": "vim::NormalBefore",
    },
  },
  // ------------------------------------------------------------------
  // TERMINAL
  // ------------------------------------------------------------------
  {
    "context": "Terminal",
    "bindings": {
      // Allow ctrl-h/j/k/l to leave the terminal and go to code panes
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",
    },
  },
  // ------------------------------------------------------------------
  // PROJECT PANEL (File Explorer)
  // ------------------------------------------------------------------
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "a": "project_panel::NewFile",
      "A": "project_panel::NewDirectory",
      "r": "project_panel::Rename",
      "d": "project_panel::Delete",
      "x": "project_panel::Cut",
      "c": "project_panel::Copy",
      "p": "project_panel::Paste",
      "q": "workspace::CloseActiveDock",
      // Navigation out of the panel
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",
    },
  },
  // ------------------------------------------------------------------
  // GIT PANEL
  // ------------------------------------------------------------------
  {
    "context": "GitPanel && not_editing",
    "bindings": {
      "q": "git_panel::Close",
    },
  },
]
